---
// manuscripts/social-network-surveys.astro
// TEMPLATE: Duplicate this file for each manuscript.
// Steps:
//   1. Copy this file, rename it to match the slug in index.astro
//   2. Fill in the metadata and draft list below
//   3. Drop PDF files in public/manuscripts/[slug]/
import BaseLayout from '../../layouts/BaseLayout.astro';

// --- Manuscript metadata ---
const manuscript = {
  title: "Social Network Surveys in Language Science Research",
  authors: "Kutlu, E., Boudreau, J., & Kim, D.J.",
  status: "In preparation",  // "In preparation" | "Under review" | "Published"
  abstract: `
    Social network analysis offers a powerful but underutilized lens for understanding
    how individuals' linguistic environments shape their language processing and production.
    This paper reviews the use of social network surveys in language science research,
    evaluates existing instruments, and proposes best practices for integrating social
    network measures into psycholinguistic and sociolinguistic study designs.
  `,
  // Add related links as { label, url } objects. Leave empty array if none.
  links: [
    // { label: "OSF Preregistration", url: "https://osf.io/..." },
    // { label: "GitHub (analysis code)", url: "https://github.com/..." },
  ],
};

// --- Draft history ---
// Most recent draft FIRST. The first entry is shown by default in the Latest tab.
// path: relative to /public — e.g. /manuscripts/social-network-surveys/v2.pdf
const drafts: { version: string; date: string; path: string; notes: string }[] = [
  // Uncomment and fill in when you have a draft to share:
  // {
  //   version: "v2",
  //   date: "2026-06-01",
  //   path: "/manuscripts/social-network-surveys/v2.pdf",
  //   notes: "Revised intro and methods section.",
  // },
  // {
  //   version: "v1",
  //   date: "2026-04-15",
  //   path: "/manuscripts/social-network-surveys/v1.pdf",
  //   notes: "Initial draft.",
  // },
];

const latestDraft = drafts[0] ?? null;
const previousDrafts = drafts.slice(1);
---

<BaseLayout title={manuscript.title} description={manuscript.abstract.trim().slice(0, 160)}>

  <!-- Back link -->
  <p style="margin-bottom: 1.5rem;">
    <a href="/manuscripts" style="font-size: 0.9rem; color: var(--color-text-muted);">← All manuscripts</a>
  </p>

  <!-- Header -->
  <h1 style="font-size: 1.5rem;">{manuscript.title}</h1>
  <p style="color: var(--color-text-muted); font-size: 0.9rem; margin-top: 0.25rem;">
    {manuscript.authors} &nbsp;·&nbsp;
    <span style={`font-weight: 500; color: ${manuscript.status === 'Published' ? '#15803d' : manuscript.status === 'Under review' ? '#b45309' : '#6b7280'}`}>
      {manuscript.status}
    </span>
  </p>

  <hr />

  <!-- Abstract -->
  <h2 style="margin-top: 1.5rem;">Abstract</h2>
  <p style="font-size: 0.95rem;">{manuscript.abstract.trim()}</p>

  <!-- Related links -->
  {manuscript.links.length > 0 && (
    <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 0.5rem; margin-bottom: 1rem;">
      {manuscript.links.map((link) => (
        <a href={link.url} target="_blank" rel="noopener" class="tag">{link.label} ↗</a>
      ))}
    </div>
  )}

  <hr />

  <!-- Draft tabs -->
  <h2>Drafts</h2>

  {drafts.length === 0 ? (
    <p class="text-muted" style="font-style: italic;">No drafts shared yet.</p>
  ) : (
    <div>
      <!-- Tab buttons -->
      <div style="display: flex; gap: 0; border-bottom: 2px solid var(--color-border); margin-bottom: 1.5rem;">
        <button
          id="tab-latest"
          onclick="showTab('latest')"
          style="padding: 0.5rem 1.25rem; border: none; background: none; cursor: pointer; font-size: 0.9rem; font-weight: 600; color: var(--color-accent); border-bottom: 2px solid var(--color-accent); margin-bottom: -2px;"
        >
          Latest
        </button>
        {previousDrafts.length > 0 && (
          <button
            id="tab-history"
            onclick="showTab('history')"
            style="padding: 0.5rem 1.25rem; border: none; background: none; cursor: pointer; font-size: 0.9rem; font-weight: 500; color: var(--color-text-muted); border-bottom: 2px solid transparent; margin-bottom: -2px;"
          >
            All versions ({drafts.length})
          </button>
        )}
      </div>

      <!-- Latest tab -->
      <div id="panel-latest">
        {latestDraft && (
          <div>
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; flex-wrap: wrap; gap: 0.5rem;">
              <span style="font-size: 0.85rem; color: var(--color-text-muted);">{latestDraft.version} · {latestDraft.date}</span>
              <a href={latestDraft.path} download class="tag">⬇ Download PDF</a>
            </div>
            <!-- Inline PDF viewer -->
            <iframe
              src={latestDraft.path}
              width="100%"
              height="700"
              style="border: 1px solid var(--color-border); border-radius: 6px;"
              title={`${manuscript.title} — ${latestDraft.version}`}
            />
          </div>
        )}
      </div>

      <!-- History tab -->
      {previousDrafts.length > 0 && (
        <div id="panel-history" style="display: none;">
          <table style="width: 100%; border-collapse: collapse; font-size: 0.9rem;">
            <thead>
              <tr style="border-bottom: 1px solid var(--color-border); text-align: left;">
                <th style="padding: 0.5rem 0.75rem; font-weight: 600;">Version</th>
                <th style="padding: 0.5rem 0.75rem; font-weight: 600;">Date</th>
                <th style="padding: 0.5rem 0.75rem; font-weight: 600;">Notes</th>
                <th style="padding: 0.5rem 0.75rem;"></th>
              </tr>
            </thead>
            <tbody>
              {drafts.map((draft) => (
                <tr style="border-bottom: 1px solid var(--color-border);">
                  <td style="padding: 0.6rem 0.75rem; font-weight: 500;">{draft.version}</td>
                  <td style="padding: 0.6rem 0.75rem; color: var(--color-text-muted);">{draft.date}</td>
                  <td style="padding: 0.6rem 0.75rem; color: var(--color-text-muted);">{draft.notes}</td>
                  <td style="padding: 0.6rem 0.75rem;">
                    <a href={draft.path} download style="font-size: 0.8rem;">⬇ PDF</a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  )}

</BaseLayout>

<script>
  function showTab(tab: string) {
    const panels = ['latest', 'history'];
    panels.forEach((p) => {
      const panel = document.getElementById(`panel-${p}`);
      const btn = document.getElementById(`tab-${p}`);
      if (!panel || !btn) return;
      const isActive = p === tab;
      panel.style.display = isActive ? 'block' : 'none';
      btn.style.color = isActive ? 'var(--color-accent)' : 'var(--color-text-muted)';
      btn.style.borderBottom = isActive ? '2px solid var(--color-accent)' : '2px solid transparent';
      btn.style.fontWeight = isActive ? '600' : '500';
    });
  }

  // Make it available globally for the onclick handlers
  (window as any).showTab = showTab;
</script>
