---
// manuscripts/sociogenerational-variability.astro
// Duplicate of the template — fill in manuscript-specific content below.
import BaseLayout from '../../layouts/BaseLayout.astro';

const manuscript = {
  title: "Sociogenerational Variability in Sentence Processing and Judgments",
  authors: "Boudreau, J., & Kutlu, E.",
  status: "In preparation",
  abstract: `
    The concept of a 'Native Speaker' is a ubiquitous but undertheorized construct in psycholinguistic research.
    This paper seeks to question the usefulness of this concept by investigating the acceptability patterns of 
    different monolingual English speakers across the lifespan.
  `,
  links: [],
};

const drafts: { version: string; date: string; path: string; notes: string }[] = [];

const latestDraft = drafts[0] ?? null;
const previousDrafts = drafts.slice(1);
---

<BaseLayout title={manuscript.title} description={manuscript.abstract.trim().slice(0, 160)}>

  <p style="margin-bottom: 1.5rem;">
    <a href="/manuscripts" style="font-size: 0.9rem; color: var(--color-text-muted);">← All manuscripts</a>
  </p>

  <h1 style="font-size: 1.5rem;">{manuscript.title}</h1>
  <p style="color: var(--color-text-muted); font-size: 0.9rem; margin-top: 0.25rem;">
    {manuscript.authors} &nbsp;·&nbsp;
    <span style="font-weight: 500; color: #6b7280;">{manuscript.status}</span>
  </p>

  <hr />

  <h2 style="margin-top: 1.5rem;">Abstract</h2>
  <p style="font-size: 0.95rem;">{manuscript.abstract.trim()}</p>

  <hr />

  <h2>Drafts</h2>
  <p class="text-muted" style="font-style: italic;">No drafts shared yet.</p>

</BaseLayout>
