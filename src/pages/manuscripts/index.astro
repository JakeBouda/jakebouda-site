---
// manuscripts/index.astro — Manuscript index
// To add a manuscript:
//   1. Add an entry to the `manuscripts` array below
//   2. Create a matching page at src/pages/manuscripts/[slug].astro
import BaseLayout from '../../layouts/BaseLayout.astro';

const manuscripts = [
  {
    slug: "SNS-paper",
    title: "Social Network Surveys in Language Science Research",
    authors: "Kutlu, E., Boudreau, J., & Kim, D.J.",
    status: "In preparation",
    year: "in prep",
    description: "A methodological paper on social network surveys as a tool in psycholinguistic research.",
    tags: ["Sociolinguistics", "Methodology"],
  },
  {
    slug: "sociogenerational",
    title: "Sociogenerational Variability in Sentence Processing and Judgments",
    authors: "Boudreau, J., & Kutlu, E.",
    status: "In preparation",
    year: "in prep",
    description: "A paper using acceptability judgments across generations of L1 English speakers to question the Native Speaker concept in psycholinguistic research.",
    tags: ["Psycholinguistics", "Native Speakers", "Monolingualism"],
  },
  {
    slug: "KVAS",
    title: "Changing Cues? How Korean Bilinguals Navigate VOT and F0 in Korean Stop Categorization",
    authors: "Boudreau, J., Kim, D.J., Kim, H., & Kutlu, E.",
    status: "In preparation",
    year: "in prep",
    description: "Investigates how different Korean bilinguals weight voice onset time (VOT) and fundamental frequency (F0) cues when categorizing both English and Korean stop consonants.",
    tags: ["Phonetics", "Bilingualism", "Visual Analog Scaling"],
  },
];

const statusColor: Record<string, string> = {
  "In preparation": "#6b7280",
  "Under review": "#b45309",
  "Published": "#15803d",
};
---

<BaseLayout title="Manuscripts" description="Academic manuscripts by Jacob Boudreau.">

  <h1>Manuscripts</h1>
  <p>
    Papers in preparation, under review, and published. Click a title to see the abstract,
    drafts, and related materials. Drafts are shared for the sake of transparency and will 
    only be posted upon acceptance. Please don't cite unpublished work without asking first 
    and note that work marked "in preparation" are subject to change.
  </p>

  <div class="card-grid" style="margin-top: 1.5rem;">
    {manuscripts.map((ms) => (
      <a href={`/manuscripts/${ms.slug}`} style="text-decoration: none; color: inherit;">
        <div class="card">
          <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; flex-wrap: wrap; margin-bottom: 0.5rem;">
            <h3 style="margin: 0; font-size: 0.975rem;">{ms.title}</h3>
            <span style={`font-size: 0.75rem; font-weight: 500; color: ${statusColor[ms.status] ?? '#6b7280'}; white-space: nowrap;`}>
              {ms.status}
            </span>
          </div>
          <p style="font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 0.5rem;">{ms.authors} ({ms.year})</p>
          <p style="font-size: 0.9rem; margin-bottom: 0.75rem;">{ms.description}</p>
          <div style="display: flex; gap: 0.4rem; flex-wrap: wrap;">
            {ms.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </div>
      </a>
    ))}
  </div>

</BaseLayout>
